#!/bin/sh
# prerm for igh-seeedstudio
set -e

case "$1" in
    remove|upgrade)
        # --- REM-01: Stop ethercat service before removal ---
        if [ -d /run/systemd/system ]; then
            systemctl stop ethercat.service || true
        fi

        # --- REM-02: Unload kernel modules in dependency order ---
        # ec_r8169 depends on ec_master, so unload ec_r8169 first
        rmmod ec_r8169 2>/dev/null || true
        rmmod ec_master 2>/dev/null || true
        ;;
esac

#DEBHELPER#

exit 0
